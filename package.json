{
  "name": "aestus",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/contracts",
    "packages/ui",
    "packages/config",
    "packages/event-bus",
    "services/context",
    "services/llm"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "lint": "eslint . && cargo clippy --workspace -- -D warnings",
    "typecheck": "bun run --filter '*' typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .prettierignore && cargo fmt --all",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\" --ignore-path .prettierignore",
    "docker:up": "docker compose -f infra/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker-compose.yml down",
    "db:migrate": "bun run --filter '@aestus/api' db:migrate",
    "db:seed": "bun run --filter '@aestus/api' db:seed",
    "nats:init": "bun run --filter '@aestus/event-bus' nats:init",
    "nats:replay": "bun run --filter '@aestus/event-bus' nats:replay"
  },
  "devDependencies": {
    "eslint": "^10.4.1",
    "prettier": "^3.3.0",
    "typescript-eslint": "^8.60.1"
  }
}
