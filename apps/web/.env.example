# apps/web .env.example — Next.js frontend
# Copy to .env.local and fill in real values. Never commit .env.local.
# NEXT_PUBLIC_* vars are inlined at build time and safe to expose to the browser.

# API base URL (the Bun API server)
NEXT_PUBLIC_API_URL=http://localhost:3001

# WebSocket / SSE stream endpoint (P15)
NEXT_PUBLIC_WS_URL=ws://localhost:3001
