# apps/api .env.example — Bun/TypeScript API server
# Copy to .env and fill in real values. Never commit .env.

PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Auth (single-user; generate a long random string)
AUTH_SECRET=change-me-to-a-long-random-secret

# Postgres (Drizzle migrations at P04)
DATABASE_URL=postgres://aestus:aestus@localhost:5432/aestus

# Redis (BullMQ queues, hot cache)
REDIS_URL=redis://localhost:6379

# NATS JetStream (event bus)
NATS_URL=nats://localhost:4222

# ClickHouse (time-series analytics)
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=aestus
CLICKHOUSE_USER=aestus
CLICKHOUSE_PASSWORD=aestus

# LLM (Ollama Cloud — see docs/credentials.md; leave empty for fixture mode)
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
LLM_REASONING_MODEL=kimi-k2.6:cloud
LLM_FAST_MODEL=minimax-m2.7:cloud

# Optional on-chain data
ETHERSCAN_API_KEY=
GLASSNODE_API_KEY=

# Optional push alerts (P25)
NTFY_TOPIC=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
