# services/ingestion .env.example — Rust ingestion service
# Copy to .env and fill in real values. Never commit .env.
# Crypto market WebSockets are public — no API keys needed for Binance/Bybit/OKX/Hyperliquid.

LOG_LEVEL=info

# Event bus
NATS_URL=nats://localhost:4222

# Hot cache (Redis — for dedup / rate-limit state)
REDIS_URL=redis://localhost:6379

# Optional on-chain data (app runs in fixture mode without these)
ETHERSCAN_API_KEY=
GLASSNODE_API_KEY=
