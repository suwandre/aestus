# infra/.env.example — Docker Compose infrastructure variables
# Copy to infra/.env. Never commit infra/.env.

# Postgres
POSTGRES_DB=aestus
POSTGRES_USER=aestus
POSTGRES_PASSWORD=aestus

# ClickHouse
CLICKHOUSE_DB=aestus
CLICKHOUSE_USER=aestus
CLICKHOUSE_PASSWORD=aestus

# Redis (no password for local dev; add requirepass in production)
REDIS_PASSWORD=

# NATS (no auth for local dev; add credentials for production)
NATS_USERNAME=
NATS_PASSWORD=
