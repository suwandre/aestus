# Root .env.example — shared / orchestration variables
# Copy to .env and fill in real values. Never commit .env.

# Environment
NODE_ENV=development

# LLM (runtime app only — see docs/credentials.md)
# Ollama Cloud subscription key; leave empty to run in fixture-only mode
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Infrastructure connection strings (mirrors infra/.env.example)
DATABASE_URL=postgres://aestus:aestus@localhost:5432/aestus
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222
CLICKHOUSE_URL=http://localhost:8123

# Optional: on-chain data providers (app runs without these in fixture mode)
ETHERSCAN_API_KEY=
GLASSNODE_API_KEY=

# Optional: away-from-desk push alerts (P25 — ntfy needs no key, Telegram does)
NTFY_TOPIC=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
