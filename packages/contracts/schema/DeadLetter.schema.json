{
  "$id": "DeadLetter.schema.json",
  "title": "DeadLetter",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "original_subject": {
      "type": "string",
      "minLength": 1
    },
    "consumer": {
      "type": "string",
      "minLength": 1
    },
    "error_type": {
      "type": "string",
      "minLength": 1
    },
    "error_message": {
      "type": "string"
    },
    "failed_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-]\\d{2}:\\d{2})))$"
    },
    "attempts": {
      "default": 1,
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "original_event": {
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "original_subject",
    "consumer",
    "error_type",
    "error_message",
    "failed_at",
    "attempts",
    "original_event"
  ],
  "additionalProperties": false
}
