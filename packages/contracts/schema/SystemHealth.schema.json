{
  "$id": "SystemHealth.schema.json",
  "title": "SystemHealth",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "service": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "degraded",
        "down"
      ]
    },
    "uptime_seconds": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "dependencies": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "degraded",
              "down"
            ]
          },
          "detail": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "status"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schema_version",
    "service",
    "version",
    "status",
    "uptime_seconds",
    "dependencies"
  ],
  "additionalProperties": false
}
