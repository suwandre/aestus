{
  "$id": "DeterministicLevels.schema.json",
  "title": "DeterministicLevels",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "reference_price": {
      "type": "number"
    },
    "direction": {
      "default": "none",
      "type": "string",
      "enum": [
        "long",
        "short",
        "none"
      ]
    },
    "entry_zone": {
      "type": "object",
      "properties": {
        "low": {
          "type": "number"
        },
        "high": {
          "type": "number"
        }
      },
      "required": [
        "low",
        "high"
      ],
      "additionalProperties": false
    },
    "invalidation": {
      "type": "number"
    },
    "targets": {
      "default": [],
      "type": "array",
      "items": {
        "type": "number"
      }
    },
    "supports": {
      "default": [],
      "type": "array",
      "items": {
        "type": "number"
      }
    },
    "resistances": {
      "default": [],
      "type": "array",
      "items": {
        "type": "number"
      }
    },
    "atr": {
      "type": "number",
      "minimum": 0
    },
    "volatility_bands": {
      "type": "object",
      "properties": {
        "atr": {
          "type": "number",
          "minimum": 0
        },
        "period": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "multiplier": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "upper": {
          "type": "number"
        },
        "lower": {
          "type": "number"
        },
        "formula": {
          "type": "string"
        }
      },
      "required": [
        "atr",
        "period",
        "multiplier",
        "upper",
        "lower",
        "formula"
      ],
      "additionalProperties": false
    },
    "liquidation_clusters": {
      "default": [],
      "type": "array",
      "items": {
        "type": "number"
      }
    },
    "candidates": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "price": {
            "type": "number"
          },
          "source": {
            "type": "string",
            "enum": [
              "swing_high",
              "swing_low",
              "atr_band",
              "liquidation_cluster",
              "volume_node",
              "pivot"
            ]
          },
          "role": {
            "type": "string",
            "enum": [
              "support",
              "resistance",
              "target",
              "invalidation",
              "context"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "note": {
            "type": "string"
          }
        },
        "required": [
          "price",
          "source",
          "role",
          "confidence"
        ],
        "additionalProperties": false
      }
    },
    "size_suggestion": {
      "default": null,
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "risk_pct": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "notional": {
              "type": "number",
              "minimum": 0
            },
            "note": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "null"
        }
      ]
    },
    "no_trade": {
      "type": "object",
      "properties": {
        "is_no_trade": {
          "type": "boolean"
        },
        "reasons": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recheck": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "is_no_trade",
        "reasons",
        "recheck"
      ],
      "additionalProperties": false
    },
    "derivations": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "component": {
            "type": "string",
            "minLength": 1
          },
          "method": {
            "type": "string",
            "minLength": 1
          },
          "inputs": {
            "default": {},
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "number"
            }
          },
          "outputs": {
            "default": [],
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "note": {
            "type": "string"
          }
        },
        "required": [
          "component",
          "method",
          "inputs",
          "outputs"
        ],
        "additionalProperties": false
      }
    },
    "method_notes": {
      "type": "string"
    }
  },
  "required": [
    "reference_price",
    "direction",
    "entry_zone",
    "invalidation",
    "targets",
    "supports",
    "resistances",
    "liquidation_clusters",
    "candidates",
    "size_suggestion",
    "derivations"
  ],
  "additionalProperties": false
}
