{
  "$id": "AnomalyEvent.schema.json",
  "title": "AnomalyEvent",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "funding_spike",
        "oi_surge",
        "volume_anomaly",
        "correlation_break",
        "basis_dislocation",
        "whale_flow",
        "macro_approaching",
        "news_cluster"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "sigma": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ]
    },
    "assets": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "venues": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "detected_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-]\\d{2}:\\d{2})))$"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "acknowledged",
        "resolved",
        "expired",
        "dismissed"
      ]
    },
    "context_refs": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rule_ref": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "id",
    "type",
    "severity",
    "sigma",
    "assets",
    "venues",
    "title",
    "description",
    "detected_at",
    "status",
    "context_refs"
  ],
  "additionalProperties": false
}
